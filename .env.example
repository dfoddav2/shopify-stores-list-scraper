# Path to SQLite database (default: data/shopify_stores.db)
# HU_SHOPIFY_DB_PATH=data/shopify_stores.db

# HTTP request timeout in seconds (default: 15)
# HU_SHOPIFY_TIMEOUT=15

# Max concurrent HTTP requests (default: 10)
# HU_SHOPIFY_CONCURRENCY=10

# Rate limit delay between requests in seconds (default: 0.5)
# HU_SHOPIFY_RATE_LIMIT=0.5

# Custom User-Agent string
# HU_SHOPIFY_USER_AGENT=Mozilla/5.0 ...

# Proxy URL (optional)
# HU_SHOPIFY_PROXY_URL=http://user:pass@host:port

# Google dorking pages per query (default: 3)
# HU_SHOPIFY_DORK_PAGES=3

# crt.sh request timeout in seconds (default: 120)
# CTRSH_TIMEOUT=120

# CT probe concurrency (default: 50)
# CT_PROBE_CONCURRENCY=50

# Run content-based HU check on remaining CT domains (default: true)
# CT_CONTENT_CHECK=true

# Max .hu domains to process from Tranco (0 = unlimited, default: 0)
# TRANCO_MAX_DOMAINS=0

# Tranco list URL (default: https://tranco-list.eu/top-1m.csv.zip)
# TRANCO_LIST_URL=https://tranco-list.eu/top-1m.csv.zip

# .hu registry announcement page URL
# HU_REGISTRY_URL=https://info.domain.hu/varolista/en/abc.html

# Skip "Private person" entries from .hu registry (default: true)
# HU_REGISTRY_SKIP_PRIVATE=true

# Cache directory for downloaded data (default: data/cache)
# HU_SHOPIFY_CACHE_DIR=data/cache

# Chrome remote debugging port for real browser profile (use your own Chrome session)
# Launch Chrome: /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222
# Set port 0 to use headless stealth mode instead (default: 0)
# HU_SHOPIFY_CHROME_DEBUG_PORT=9222

# Google Custom Search API credentials (required for --direct-search)
# Get API key: https://console.cloud.google.com/apis/credentials
# Get CSE ID: https://cse.google.com/cse/ (create "Search entire web" engine)
# HU_SHOPIFY_GOOGLE_API_KEY=
# HU_SHOPIFY_GOOGLE_CSE_ID=

# Comma-separated list of Shopify App Store slugs to scrape reviews from
# Example: HU_SHOPIFY_APP_SLUGS=teeinblue,szamlazz-hu-1,kosr
# HU_SHOPIFY_APP_SLUGS=

